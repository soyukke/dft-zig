# ABINIT SCF calculation for silicon benchmark
# Primitive cell (2 atoms), ecut=15 Ry = 7.5 Ha, 4x4x4 k-mesh

pp_dirpath "../../../pseudo"
pseudos "Si.upf"

# Output file prefix
outdata_prefix "abinit_scfo"
tmpdata_prefix "abinit_scf_tmp"

ntypat 1
znucl 14
natom 2
typat 1 1

# Primitive FCC cell: a/2 * [(0,1,1), (1,0,1), (1,1,0)]
# a = 5.431 Angstrom = 10.2631 bohr, a/2 = 5.1315 bohr
acell 3*5.1315

rprim
  0.0 1.0 1.0
  1.0 0.0 1.0
  1.0 1.0 0.0

# Diamond structure: atoms at (0,0,0) and (1/4,1/4,1/4)
xred
  0.00 0.00 0.00
  0.25 0.25 0.25

# ecut = 15 Ry = 7.5 Ha
ecut 7.5
nband 8
ixc 11  # PBE

iscf 7
diemix 0.3
tolvrs 1.0d-8
nstep 50

occopt 3
tsmear 0.01

kptopt 1
ngkpt 4 4 4
nshiftk 1
shiftk 0.0 0.0 0.0
