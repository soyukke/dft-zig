# ABINIT band calculation for graphene benchmark
# G -> K -> M -> G path with 61 k-points

pp_dirpath "../../pseudo"
pseudos "C.upf"

ntypat 1
znucl 6
natom 2
typat 1 1

acell 1 1 1
rprim
  4.6487262675 0.0 0.0
  2.3243631337 4.0259150366 0.0
  0.0 0.0 18.8972612

xred
  0.0 0.0 0.0
  0.33333333 0.33333333 0.0

ecut 7.5
nband 8

# Non-SCF band calculation
ixc 11  # PBE (matching UPF pseudopotential)
iscf -2
irdden 1
tolwfr 1.0d-12
nstep 50

occopt 3
tsmear 0.01

# G -> K -> M -> G path (61 k-points, same density as DFT-Zig with points=20)
kptopt 0
nkpt 61
kpt
