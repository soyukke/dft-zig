# ABINIT band calculation for Cu benchmark
# FCC primitive cell (1 atom), G -> X -> W -> K -> G -> L path

pp_dirpath "../../pseudo"
pseudos "Cu_ONCV_PBE-1.2.upf"

indata_prefix "abinit_bandi"
outdata_prefix "abinit_bando"
tmpdata_prefix "abinit_band_tmp"

ntypat 1
znucl 29
natom 1
typat 1

acell 3*3.4155

rprim
  0.0 1.0 1.0
  1.0 0.0 1.0
  1.0 1.0 0.0

xred
  0.00 0.00 0.00

ecut 30.0
nband 16
ixc 11  # PBE

# Non-SCF band calculation
iscf -2
irdden 1
tolwfr 1.0d-12
nstep 50

occopt 3
tsmear 0.01

# G -> X -> W -> K -> G -> L path (101 k-points)
# FCC BZ: G=(0,0,0), X=(0.5,0,0.5), W=(0.5,0.25,0.75), K=(0.375,0.375,0.75), L=(0.5,0.5,0.5)
kptopt 0
nkpt 101
kpt
